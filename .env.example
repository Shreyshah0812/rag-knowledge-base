# --- LLM / embeddings providers ---
OPENAI_API_KEY=sk-your-key-here
# Optional: only needed if you swap the generator to Anthropic per BLUEPRINT.md
ANTHROPIC_API_KEY=

# --- Reranker ---
COHERE_API_KEY=your-cohere-key-here

# --- Postgres ---
DATABASE_URL=postgresql://rag:rag@postgres:5432/rag_kb

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- Retrieval ---
BM25_TOP_K=20
VECTOR_TOP_K=20
RRF_K=60
RERANK_TOP_K=5
RERANK_THRESHOLD=0.3

# --- Generation ---
GENERATION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_TEMPERATURE=0
ENABLE_SELF_CHECK=true

# --- Misc ---
LOG_LEVEL=INFO
RAW_FILE_STORAGE_DIR=/data/uploads
